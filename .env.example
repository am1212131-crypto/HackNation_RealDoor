# Copy this file to .env and fill in your own key. Never commit .env.
# .env is already listed in .gitignore.

# Required only for the two OPTIONAL AI features below. If left unset,
# RealDoor runs entirely on deterministic regex extraction + structured
# table lookups -- it still works, it just won't backfill unrecognized
# Profile fields or answer narrative (non-numeric) rules questions.
OPENAI_API_KEY=

# Optional: override the chat model used for the extraction fallback and
# the RAG answer generation.
REALDOOR_LLM_MODEL=gpt-4o-mini

# Optional: override the embedding model used to index the narrative rules
# corpus (data/rag/chunks.json) for the RAG query path.
REALDOOR_EMBEDDING_MODEL=text-embedding-3-small
